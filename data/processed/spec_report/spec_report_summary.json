{
  "authoritative_specs": [
    {
      "spec_id": "F",
      "need_id_ref": "3.0",
      "description": "The wheelchair shall achieve an average forward acceleration of at least 2.85 m/s^2 from rest over the first 5 m of travel.",
      "justification": "Wheelchair basketball sprint studies report a 5 m sprint time of approximately 1.87 s for competitive players, corresponding to an average acceleration of about 2.86 m/s^2 [29].",
      "required": true
    },
    {
      "spec_id": "G",
      "need_id_ref": "3.0",
      "description": "The wheelchair shall achieve a maximum forward speed of at least 11.0 mph.",
      "justification": "Elite wheelchair basketball sprint testing reports peak velocities of approximately 5.3 m/s (\u224811.9 mph). A target of 11 mph is therefore slightly conservative relative to elite performance [30].",
      "required": true
    },
    {
      "spec_id": "H",
      "need_id_ref": "3,4",
      "description": "The wheelchair shall achieve a angular velocity of at least 200 deg/s within 0.50 s from neutral motion.",
      "justification": "Elite wheelchair basketball sprint data show athletes reach approximately 3.4 to 4.0 m/s within the first 5 m [30], and wheelchair court-sport agility data report turning radii of approximately 0.94 to 0.98 m [31]. These values correspond to turning rates on the order of 200 to 240 deg/s, so 200 deg/s was selected as a conservative, data-driven target.",
      "required": true
    },
    {
      "spec_id": "O",
      "need_id_ref": "10.0",
      "description": "The wheelchair shall operate for at least 2.0 h on a full battery charge under normal athletic use without requiring recharge or battery replacement.",
      "justification": "The wheelchair must support a full practice or game session without interruption so that battery limits do not prevent normal use.",
      "required": true
    }
  ],
